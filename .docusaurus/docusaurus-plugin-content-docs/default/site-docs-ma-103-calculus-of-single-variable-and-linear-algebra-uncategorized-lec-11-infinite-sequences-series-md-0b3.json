    "key_formulas": [
      {
        "name": "Epsilon-Delta Definition of Limit",
        "formula": "\\forall \\epsilon > 0, \\exists N \\in \\mathbb{Z}^+ \\text{ s.t. } \\forall n > N, |a_n - L| < \\epsilon",
        "note": "A sequence $a_n$ converges to $L$ if terms eventually get arbitrarily close to $L$."
      },
      {
        "name": "Partial Sum of a Geometric Series",
        "formula": "S_n = \\frac{a(1-r^n)}{1-r}",
        "note": "Sum of the first $n$ terms of a geometric series with first term $a$ and common ratio $r$."
      },
      {
        "name": "Sum of a Convergent Geometric Series",
        "formula": "S = \\frac{a}{1-r}",
        "note": "The sum of an infinite geometric series if the common ratio $|r| < 1$."
      },
      {
        "name": "Limit of (1+x/n)^n",
        "formula": "\\lim_{n \\to \\infty} \\left(1 + \\frac{x}{n}\\right)^n = e^x",
        "note": "A fundamental limit definition for the exponential function."
      },
      {
        "name": "Limit of x^n/n!",
        "formula": "\\lim_{n \\to \\infty} \\frac{x^n}{n!} = 0",
        "note": "Factorial growth outpaces exponential growth for any $x$."
      }
    ]
  },
