    "key_formulas": [
      {
        "name": "Average Value of a Function",
        "formula": "av(f) = \\frac{1}{b-a} \\int_{a}^{b} f(x) dx",
        "note": "For an integrable function $f$ on $[a, b]$."
      },
      {
        "name": "Mean Value Theorem for Definite Integrals",
        "formula": "f(c) = \\frac{1}{b-a} \\int_{a}^{b} f(x) dx",
        "note": "For a continuous function $f$ on $[a, b]$, there exists a $c \\in [a, b]$."
      },
      {
        "name": "Substitution in Definite Integrals",
        "formula": "\\int_{a}^{b} f(g(x)) g'(x) dx = \\int_{g(a)}^{g(b)} f(u) du",
        "note": "Also known as u-substitution for definite integrals."
      },
      {
        "name": "Area Between Two Curves",
        "formula": "A = \\int_{a}^{b} (f(x) - g(x)) dx",
        "note": "When $f(x) \\ge g(x)$ on $[a, b]$."
      },
      {
        "name": "Area Between Two Curves (w.r.t y)",
        "formula": "A = \\int_{c}^{d} (f(y) - g(y)) dy",
        "note": "When $f(y) \\ge g(y)$ on $[c, d]$."
      },
      {
        "name": "Type I Improper Integral (Infinite Upper Limit)",
        "formula": "\\int_{a}^{\\infty} f(x) dx = \\lim_{b \\to \\infty} \\int_{a}^{b} f(x) dx",
        "note": "Converges if the limit is finite, diverges otherwise."
      },
      {
        "name": "Type I Improper Integral (Infinite Lower Limit)",
        "formula": "\\int_{-\\infty}^{b} f(x) dx = \\lim_{a \\to -\\infty} \\int_{a}^{b} f(x) dx",
        "note": "Converges if the limit is finite, diverges otherwise."
      },
      {
        "name": "Type II Improper Integral (Discontinuity at Lower Limit)",
        "formula": "\\int_{a}^{b} f(x) dx = \\lim_{c \\to a^+} \\int_{c}^{b} f(x) dx",
        "note": "For $f$ discontinuous at $a$."
      },
      {
        "name": "Type II Improper Integral (Discontinuity at Upper Limit)",
        "formula": "\\int_{a}^{b} f(x) dx = \\lim_{c \\to b^-} \\int_{a}^{c} f(x) dx",
        "note": "For $f$ discontinuous at $b$."
      },
      {
        "name": "General Integration Formula: $\\int \\cos(ax) dx$",
        "formula": "\\frac{1}{a} \\sin(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int \\sin(ax) dx$",
        "formula": "-\\frac{1}{a} \\cos(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int \\sec^2(ax) dx$",
        "formula": "\\frac{1}{a} \\tan(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int \\csc^2(ax) dx$",
        "formula": "-\\frac{1}{a} \\cot(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int \\sec(ax) \\tan(ax) dx$",
        "formula": "\\frac{1}{a} \\sec(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int \\csc(ax) \\cot(ax) dx$",
        "formula": "-\\frac{1}{a} \\csc(ax) + C",
        "note": "Common trigonometric integral."
      },
      {
        "name": "General Integration Formula: $\\int e^{ax} dx$",
        "formula": "\\frac{1}{a} e^{ax} + C",
        "note": "Integral of exponential function."
      },
      {
        "name": "General Integration Formula: $\\int b^x dx$",
        "formula": "\\frac{b^x}{\\ln b} + C, b > 0, b \\neq 1",
        "note": "Integral of a general exponential function."
      },
      {
        "name": "General Integration Formula: $\\int \\frac{dx}{a^2 + x^2}$",
        "formula": "\\frac{1}{a} \\tan^{-1}\\left(\\frac{x}{a}\\right) + C",
        "note": "Integral resulting in inverse tangent."
      },
      {
        "name": "General Integration Formula: $\\int \\frac{dx}{\\sqrt{a^2 - x^2}}$",
        "formula": "\\sin^{-1}\\left(\\frac{x}{a}\\right) + C, a > 0",
        "note": "Integral resulting in inverse sine."
      },
      {
        "name": "General Integration Formula: $\\int \\frac{dx}{x\\sqrt{x^2 - a^2}}$",
        "formula": "\\frac{1}{a} \\sec^{-1}\\left|\\frac{x}{a}\\right| + C, a > 0",
        "note": "Integral resulting in inverse secant."
      }
    ]
  },
